# ─────────────────────────────────────────────────────────────────────────────
# LOGO BRIEF APP — Environment Configuration
# Copy this file to .env and fill in your values.
# !! Never commit .env to git !!
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000

# Your admin panel password — choose something strong
ADMIN_KEY=change-this-to-something-very-secret

# Your email address — where new brief notifications land
DESIGNER_EMAIL=you@youremail.com

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: use an App Password (Google Account → Security → App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Your deployed app URL (used in email links)
APP_URL=https://yourdomain.com
